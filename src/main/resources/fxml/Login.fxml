<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.prison.controller.LoginController" 
            style="-fx-background-color: #000000;"
            prefWidth="900" prefHeight="700">
    
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40; -fx-background-color: #1a1a1a; -fx-background-radius: 15;" maxWidth="450">
            
            <Label text="Prison Management System" style="-fx-text-fill: #ffffff; -fx-font-size: 28px; -fx-font-weight: bold;" />
            
            <Label text="Login to Your Account" style="-fx-text-fill: #cccccc; -fx-font-size: 16px;" />
            
            <VBox spacing="5">
                <Label text="Username" style="-fx-text-fill: #ffffff; -fx-font-size: 14px;" />
                <TextField fx:id="usernameField" promptText="Enter your username" 
                          style="-fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #888888; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"
                          prefHeight="40" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Password" style="-fx-text-fill: #ffffff; -fx-font-size: 14px;" />
                <PasswordField fx:id="passwordField" promptText="Enter your password" 
                              style="-fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #888888; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"
                              prefHeight="40" />
            </VBox>
            
            <Label fx:id="errorLabel" style="-fx-text-fill: #ff4444; -fx-font-size: 12px;" />
            
            <Button text="Login" onAction="#handleLogin" 
                    style="-fx-background-color: #ffffff; -fx-text-fill: #000000; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                    prefWidth="400" prefHeight="45" />
            
            <VBox alignment="CENTER" spacing="5">
                <Label text="Don't have an account?" style="-fx-text-fill: #cccccc; -fx-font-size: 12px;" />
                <Hyperlink text="Sign Up Here" onAction="#openSignup" 
                          style="-fx-text-fill: #ffffff; -fx-underline: true; -fx-font-size: 13px; -fx-font-weight: bold;" />
            </VBox>
            
        </VBox>
    </center>
    
</BorderPane>