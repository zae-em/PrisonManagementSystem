<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.prison.controller.ManageStaffController"
      spacing="15" style="-fx-padding: 20;">
    
    <Label text="Manage Staff Records" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <HBox spacing="10">
        <Button text="Add New Staff" onAction="#showAddStaffForm" prefWidth="120" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Update Selected" onAction="#updateStaff" prefWidth="120" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Delete Selected" onAction="#deleteStaff" prefWidth="120" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="Back" onAction="#goBack" prefWidth="120"/>
    </HBox>
    
    <TableView fx:id="staffTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="staffIdColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="150"/>
            <TableColumn fx:id="roleColumn" text="Role" prefWidth="120"/>
            <TableColumn fx:id="shiftColumn" text="Shift" prefWidth="100"/>
            <TableColumn fx:id="contactColumn" text="Contact" prefWidth="180"/>
        </columns>
    </TableView>
    
    <VBox fx:id="staffForm" spacing="10" style="-fx-border-color: #bdc3c7; -fx-border-width: 1; -fx-padding: 15;">
        <Label text="Staff Details" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10" vgap="10">
            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="staffNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>
            
            <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <ComboBox fx:id="roleCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>
            
            <Label text="Shift:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="shiftCombo" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="250"/>
            
            <Label text="Contact Info:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="contactField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="250"/>
        </GridPane>
        
        <HBox spacing="10">
            <Button text="Save" onAction="#saveStaff" prefWidth="100" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
            <Button text="Cancel" onAction="#cancelForm" prefWidth="100"/>
        </HBox>
    </VBox>
    
    <Label fx:id="statusLabel" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
</VBox>
