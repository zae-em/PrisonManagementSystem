<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.prison.controller.MedicalCheckupController"
      spacing="15" style="-fx-padding: 20;">
    
    <Label text="Medical Checkup" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="Select Inmate:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="inmateCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
        
        <Label text="Checkup Date:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <DatePicker fx:id="checkupDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>
        
        <Label text="Diagnosis:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="diagnosisField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
        
        <Label text="Treatment:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="treatmentField" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300"/>
        
        <Label text="Doctor Name:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="doctorNameField" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300"/>
        
        <Label text="Notes:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextArea fx:id="notesArea" GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="300" prefHeight="80"/>
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Save Checkup" onAction="#saveCheckup" prefWidth="120" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Clear" onAction="#clearFields" prefWidth="120"/>
        <Button text="Back" onAction="#goBack" prefWidth="120"/>
    </HBox>
    
    <Separator/>
    
    <Label text="Recent Medical Checkups" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TableView fx:id="checkupsTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="checkupIdColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="inmateIdColumn" text="Inmate ID" prefWidth="80"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
            <TableColumn fx:id="diagnosisColumn" text="Diagnosis" prefWidth="150"/>
            <TableColumn fx:id="treatmentColumn" text="Treatment" prefWidth="150"/>
            <TableColumn fx:id="doctorColumn" text="Doctor" prefWidth="120"/>
        </columns>
    </TableView>
    
    <Label fx:id="statusLabel" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
</VBox>
