<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.prison.controller.RecordMovementController"
      spacing="15" style="-fx-padding: 20;">
    
    <Label text="Record Inmate Movement" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="Select Inmate:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="inmateCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
        
        <Label text="From Location:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="fromLocationField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>
        
        <Label text="To Location:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="toLocationField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
        
        <Label text="Reason:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="reasonCombo" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300"/>
        
        <Label text="Authorized By:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="authorizedByField" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300"/>
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Record Movement" onAction="#recordMovement" prefWidth="150" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Clear" onAction="#clearFields" prefWidth="120"/>
        <Button text="Back" onAction="#goBack" prefWidth="120"/>
    </HBox>
    
    <Separator/>
    
    <Label text="Recent Movement Records" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TableView fx:id="movementsTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="movementIdColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="inmateIdColumn" text="Inmate" prefWidth="80"/>
            <TableColumn fx:id="fromColumn" text="From" prefWidth="120"/>
            <TableColumn fx:id="toColumn" text="To" prefWidth="120"/>
            <TableColumn fx:id="timeColumn" text="Time" prefWidth="150"/>
            <TableColumn fx:id="reasonColumn" text="Reason" prefWidth="120"/>
        </columns>
    </TableView>
    
    <Label fx:id="statusLabel" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
</VBox>
