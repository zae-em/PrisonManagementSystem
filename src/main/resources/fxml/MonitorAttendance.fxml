<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.prison.controller.MonitorAttendanceController"
      spacing="15" style="-fx-padding: 20;">
    
    <Label text="Monitor Inmate Attendance" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="Select Inmate:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="inmateCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
        
        <Label text="Work Assignment:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="workAssignmentCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>
        
        <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
        
        <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="statusCombo" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300"/>
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Record Attendance" onAction="#recordAttendance" prefWidth="150" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="View Report" onAction="#viewReport" prefWidth="120" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Back" onAction="#goBack" prefWidth="120"/>
    </HBox>
    
    <Separator/>
    
    <Label text="Attendance Summary" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TextArea fx:id="attendanceReportArea" prefHeight="200" editable="false" 
              style="-fx-control-inner-background: #ecf0f1;"/>
    
    <Label fx:id="statusLabel" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
</VBox>
