<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.prison.controller.IncidentReportController"
      spacing="15" style="-fx-padding: 20;">
    
    <Label text="Record Incident Report" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10">
        <Label text="Inmate Involved:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <ComboBox fx:id="inmateCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="300"/>
        
        <Label text="Incident Type:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="incidentTypeCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="300"/>
        
        <Label text="Reported By:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="reportedByField" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="300"/>
        
        <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextArea fx:id="descriptionArea" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="300" prefHeight="100"/>
        
        <Label text="Action Taken:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextArea fx:id="actionTakenArea" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="300" prefHeight="80"/>
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER">
        <Button text="Save Report" onAction="#saveReport" prefWidth="120" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Clear" onAction="#clearFields" prefWidth="120"/>
        <Button text="Back" onAction="#goBack" prefWidth="120"/>
    </HBox>
    
    <Separator/>
    
    <Label text="Recent Incident Reports" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TableView fx:id="reportsTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="reportIdColumn" text="ID" prefWidth="50"/>
            <TableColumn fx:id="inmateIdColumn" text="Inmate" prefWidth="80"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="120"/>
            <TableColumn fx:id="dateColumn" text="Date/Time" prefWidth="150"/>
            <TableColumn fx:id="reportedByColumn" text="Reported By" prefWidth="120"/>
        </columns>
    </TableView>
    
    <Label fx:id="statusLabel" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
</VBox>
