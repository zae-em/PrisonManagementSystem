<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.prison.controller.SignupController" 
            style="-fx-background-color: #000000;"
            prefWidth="900" prefHeight="700">
    
    <center>
        <VBox alignment="CENTER" spacing="15" style="-fx-padding: 30; -fx-background-color: #1a1a1a; -fx-background-radius: 15;" maxWidth="450">
            
            <Label text="Create New Account" style="-fx-text-fill: #ffffff; -fx-font-size: 26px; -fx-font-weight: bold;" />
            
            <Label text="Register to access the system" style="-fx-text-fill: #cccccc; -fx-font-size: 14px;" />
            
            <VBox spacing="5">
                <Label text="Full Name" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;" />
                <TextField fx:id="fullNameField" promptText="Enter full name" 
                          style="-fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #888888; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"
                          prefHeight="35" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Username" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;" />
                <TextField fx:id="usernameField" promptText="Choose a username" 
                          style="-fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #888888; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"
                          prefHeight="35" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Email" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;" />
                <TextField fx:id="emailField" promptText="Enter email address" 
                          style="-fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #888888; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"
                          prefHeight="35" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Password" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;" />
                <PasswordField fx:id="passwordField" promptText="Create password" 
                              style="-fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #888888; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"
                              prefHeight="35" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Confirm Password" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;" />
                <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" 
                              style="-fx-background-color: #2a2a2a; -fx-text-fill: #ffffff; -fx-prompt-text-fill: #888888; -fx-border-color: #444444; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;"
                              prefHeight="35" />
            </VBox>
            
            <VBox spacing="5">
                <Label text="Role" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;" />
                <ComboBox fx:id="roleCombo" promptText="Select your role" 
                         style="-fx-background-color: #2a2a2a;"
                         prefHeight="35" prefWidth="390" />
            </VBox>
            
            <Label fx:id="errorLabel" style="-fx-text-fill: #ff4444; -fx-font-size: 11px;" wrapText="true" />
            
            <Button text="Sign Up" onAction="#handleSignup" 
                    style="-fx-background-color: #ffffff; -fx-text-fill: #000000; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                    prefWidth="390" prefHeight="40" />
            
            <VBox alignment="CENTER" spacing="5">
                <Label text="Already have an account?" style="-fx-text-fill: #cccccc; -fx-font-size: 11px;" />
                <Hyperlink text="Login Here" onAction="#openLogin" 
                          style="-fx-text-fill: #ffffff; -fx-underline: true; -fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>
            
        </VBox>
    </center>
    
</BorderPane>